SMTP_ADDRESS=smtp.example.com
SMTP_PORT=587
SMTP_DOMAIN=example.com
SMTP_USERNAME=your_username
SMTP_PASSWORD=your_password
BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_PATH=/api/*

# Third-party API keys
VITE_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
VITE_GNEWS_API_KEY=
VITE_NEWSAPI_KEY=
VITE_FINANCIAL_MODELING_PREP_API_KEY=
VITE_ALPHA_VANTAGE_API_KEY=
VITE_NEWSDATA_API_KEY=
VITE_GUARDIAN_API_KEY=
VITE_WORDNIK_API_KEY=
VITE_NASA_API_KEY=

# Firebase web app config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Keka integration
KEKA_API_KEY_ENCRYPTION_KEY=

# Rails encryption key
RAILS_MASTER_KEY=

# Optional: customize Puma threads/workers
RAILS_MAX_THREADS=5
RAILS_MIN_THREADS=5
WEB_CONCURRENCY=2

# Database connection
DB_HOST=localhost
# DATABASE_URL=

# Redis for Action Cable
REDIS_URL=redis://localhost:6379/1

# Slack notifications
SLACK_WEBHOOK_URL=

# Misc settings
RAILS_LOG_LEVEL=info
CI=false
RACK_ATTACK_LOGIN_PER_MINUTE=20
RACK_ATTACK_REQUESTS_PER_MINUTE=300
RACK_ATTACK_SIGNUP_PER_HOUR=10
RACK_ATTACK_DEMO_PER_MINUTE=20
DEMO_MODE_ENABLED=false
PORTFOLIO_ADMIN_EMAIL=
