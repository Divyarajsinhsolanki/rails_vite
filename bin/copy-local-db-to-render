#!/usr/bin/env bash
set -euo pipefail

command -v psql >/dev/null 2>&1 || {
  echo "psql is required." >&2
  exit 1
}

if [ -z "${RENDER_DATABASE_URL:-}" ]; then
  if [ -t 0 ]; then
    read -r -s -p "Render External Database URL: " RENDER_DATABASE_URL
    echo
    export RENDER_DATABASE_URL
  else
    echo "Set RENDER_DATABASE_URL to the External Database URL from Render Postgres." >&2
    exit 1
  fi
fi

if [ -z "${RENDER_DATABASE_URL}" ]; then
  echo "Render External Database URL cannot be empty." >&2
  exit 1
fi

if [ "${CONFIRM_DATABASE_REPLACE:-}" != "replace-render-database" ]; then
  cat >&2 <<'WARNING'
This operation replaces the Render database with your local development database.
Suspend application writes first, then run with:

  CONFIRM_DATABASE_REPLACE=replace-render-database bin/copy-local-db-to-render
WARNING
  exit 1
fi

local_database_url="${LOCAL_DATABASE_URL:-postgresql://postgres:postgres@${DB_HOST:-localhost}/pdf_master_development}"
timestamp="$(date -u +%Y%m%dT%H%M%SZ)"
backup_dir="${DATABASE_BACKUP_DIR:-tmp/database-copies}"
local_dump="${backup_dir}/local-${timestamp}.dump"
production_backup="${backup_dir}/render-before-local-copy-${timestamp}.dump"

mkdir -p "${backup_dir}"

local_server_major="$(
  psql "${local_database_url}" --no-align --tuples-only --command="SHOW server_version_num" |
    tr -d '[:space:]' |
    awk '{ print int($1 / 10000) }'
)"
render_server_major="$(
  psql "${RENDER_DATABASE_URL}" --no-align --tuples-only --command="SHOW server_version_num" |
    tr -d '[:space:]' |
    awk '{ print int($1 / 10000) }'
)"

required_client_major="${local_server_major}"
if [ "${render_server_major}" -gt "${required_client_major}" ]; then
  required_client_major="${render_server_major}"
fi

client_mode="native"
native_client_major=0
if command -v pg_dump >/dev/null 2>&1 && command -v pg_restore >/dev/null 2>&1; then
  native_client_major="$(pg_dump --version | awk '{ print $3 }' | cut -d. -f1)"
fi

if [ "${native_client_major}" -lt "${required_client_major}" ]; then
  command -v docker >/dev/null 2>&1 || {
    echo "PostgreSQL client ${native_client_major} is too old and Docker is unavailable." >&2
    echo "Install PostgreSQL client ${required_client_major} or newer." >&2
    exit 1
  }

  client_mode="docker"
  postgres_client_image="${POSTGRES_CLIENT_IMAGE:-postgres:${required_client_major}-alpine}"
  echo "Native PostgreSQL client ${native_client_major} is too old; using ${postgres_client_image}."

  docker_client_major="$(
    docker run --rm "${postgres_client_image}" pg_dump --version |
      awk '{ print $3 }' |
      cut -d. -f1
  )"
  if [ "${docker_client_major}" -lt "${required_client_major}" ]; then
    echo "Docker PostgreSQL client ${docker_client_major} is too old." >&2
    exit 1
  fi
fi

dump_database() {
  local database_url="$1"
  local output_file="$2"

  if [ "${client_mode}" = "native" ]; then
    pg_dump \
      --format=custom \
      --no-owner \
      --no-privileges \
      --file="${output_file}" \
      "${database_url}"
  else
    docker run \
      --rm \
      --network host \
      --env DATABASE_URL="${database_url}" \
      "${postgres_client_image}" \
      sh -c 'pg_dump --format=custom --no-owner --no-privileges "$DATABASE_URL"' \
      > "${output_file}"
  fi
}

restore_database() {
  local database_url="$1"
  local input_file="$2"

  if [ "${client_mode}" = "native" ]; then
    pg_restore \
      --clean \
      --if-exists \
      --single-transaction \
      --no-owner \
      --no-privileges \
      --exit-on-error \
      --dbname="${database_url}" \
      "${input_file}"
  else
    docker run \
      --rm \
      --interactive \
      --network host \
      --env DATABASE_URL="${database_url}" \
      "${postgres_client_image}" \
      sh -c 'pg_restore --clean --if-exists --single-transaction --no-owner --no-privileges --exit-on-error --dbname="$DATABASE_URL"' \
      < "${input_file}"
  fi
}

echo "Backing up the current Render database to ${production_backup}..."
dump_database "${RENDER_DATABASE_URL}" "${production_backup}"

echo "Dumping the local development database to ${local_dump}..."
dump_database "${local_database_url}" "${local_dump}"

echo "Replacing the Render database..."
restore_database "${RENDER_DATABASE_URL}" "${local_dump}"

echo "Render database replaced successfully."
echo "Production backup: ${production_backup}"
echo "Local dump: ${local_dump}"
