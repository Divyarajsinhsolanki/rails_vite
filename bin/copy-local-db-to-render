#!/usr/bin/env bash
set -euo pipefail

command -v pg_dump >/dev/null 2>&1 || {
  echo "pg_dump is required." >&2
  exit 1
}
command -v pg_restore >/dev/null 2>&1 || {
  echo "pg_restore is required." >&2
  exit 1
}
command -v psql >/dev/null 2>&1 || {
  echo "psql is required." >&2
  exit 1
}

if [ -z "${RENDER_DATABASE_URL:-}" ]; then
  echo "Set RENDER_DATABASE_URL to the External Database URL from Render Postgres." >&2
  exit 1
fi

if [ "${CONFIRM_DATABASE_REPLACE:-}" != "replace-render-database" ]; then
  cat >&2 <<'WARNING'
This operation replaces the Render database with your local development database.
Suspend application writes first, then run with:

  CONFIRM_DATABASE_REPLACE=replace-render-database \
  RENDER_DATABASE_URL='postgresql://...' \
  bin/copy-local-db-to-render
WARNING
  exit 1
fi

local_database_url="${LOCAL_DATABASE_URL:-postgresql://postgres:postgres@${DB_HOST:-localhost}/pdf_master_development}"
timestamp="$(date -u +%Y%m%dT%H%M%SZ)"
backup_dir="${DATABASE_BACKUP_DIR:-tmp/database-copies}"
local_dump="${backup_dir}/local-${timestamp}.dump"
production_backup="${backup_dir}/render-before-local-copy-${timestamp}.dump"

mkdir -p "${backup_dir}"

client_major="$(pg_dump --version | awk '{ print $3 }' | cut -d. -f1)"
local_server_major="$(
  psql "${local_database_url}" --no-align --tuples-only --command="SHOW server_version_num" |
    tr -d '[:space:]' |
    awk '{ print int($1 / 10000) }'
)"
render_server_major="$(
  psql "${RENDER_DATABASE_URL}" --no-align --tuples-only --command="SHOW server_version_num" |
    tr -d '[:space:]' |
    awk '{ print int($1 / 10000) }'
)"

if [ "${client_major}" -lt "${local_server_major}" ] || [ "${client_major}" -lt "${render_server_major}" ]; then
  echo "PostgreSQL client ${client_major} is too old." >&2
  echo "Install client tools ${local_server_major} or newer for local and ${render_server_major} or newer for Render." >&2
  exit 1
fi

echo "Backing up the current Render database to ${production_backup}..."
pg_dump \
  --format=custom \
  --no-owner \
  --no-privileges \
  --file="${production_backup}" \
  "${RENDER_DATABASE_URL}"

echo "Dumping the local development database to ${local_dump}..."
pg_dump \
  --format=custom \
  --no-owner \
  --no-privileges \
  --file="${local_dump}" \
  "${local_database_url}"

echo "Replacing the Render database..."
pg_restore \
  --clean \
  --if-exists \
  --single-transaction \
  --no-owner \
  --no-privileges \
  --exit-on-error \
  --dbname="${RENDER_DATABASE_URL}" \
  "${local_dump}"

echo "Render database replaced successfully."
echo "Production backup: ${production_backup}"
echo "Local dump: ${local_dump}"
